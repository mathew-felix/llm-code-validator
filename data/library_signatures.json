  "pandas": {
    "current_version": "2.x",
    "last_updated": "2026-04-07",
    "methods": {
      "append": {
        "exists": false,
        "removed_in": "2.0.0",
        "reason": "DataFrame.append was deprecated and then removed in 2.0.0. Use pd.concat instead.",
        "old_usage": "df1.append(df2)",
        "replacement": "pd.concat([df1, df2])"
      },
      "mad": {
        "exists": false,
        "removed_in": "2.0.0",
        "reason": "mad() was removed in 2.0.0.",
        "old_usage": "df.mad()",
        "replacement": "(df - df.mean()).abs().mean()"
      },
      "Int64Index": {
        "exists": false,
        "removed_in": "2.0.0",
        "reason": "NumericIndex types were removed in 2.0.0",
        "old_usage": "pd.Int64Index([1, 2, 3])",
        "replacement": "pd.Index([1, 2, 3], dtype='int64')"
      }
    }
  },
